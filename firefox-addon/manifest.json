{
  "manifest_version": 2,
  "name": "アドホック・ニコ オーバーレイ",
  "version": "1.1.0",
  "description": "アドホック・ニコのコメントをブラウザウィンドウにオーバーレイ表示",
  "permissions": [
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "アドホック・ニコ",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "background": {
    "scripts": ["config.js", "background/background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content/overlay.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
